DATABASE_URL=sqlite:///./hiring_db.db
OLLAMA_URL=http://localhost:11434/api/generate
MODEL_NAME=glm4

# --- New Google Forms Integration ---
# (Optional) If you want to automatically push the generated AI assessment to Google Forms.
# Leave blank to use the local Database/UI-only mock integration.

# 1. Provide the Google Form ID (from the URL of your Google Form)
GOOGLE_FORM_ID=your_google_form_id_here

# 2. Provide a Google Cloud API Key with Forms API enabled
GOOGLE_API_KEY=your_google_cloud_api_key_here
